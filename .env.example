# Claude subscription token (from `claude setup-token`). This is what powers the
# price engine — no OpenAI, no paid API key.
CLAUDE_CODE_OAUTH_TOKEN=

# Where the SQLite cache + price history live. On Railway, attach a volume and
# set this to the mount path so data survives redeploys.
DATA_DIR=/data

# How long a cached price stays "fresh" before a new live lookup (ms). Default 12h.
CACHE_TTL_MS=43200000

# Optional: turn on the direct Carrefour adapter once its endpoint is verified.
CARREFOUR_ADAPTER=off
# CARREFOUR_STORE_ID=
# CARREFOUR_APP_ID=
